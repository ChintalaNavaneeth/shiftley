                "employer_subscription_monthly": {
                    "type": "number"
                },
                "employer_subscription_weekly": {
                    "type": "number"
                },
                "worker_cancel_penalty": {
                    "type": "number"
                }
            }
        },
        "admin.CreateCategoryRequest": {
            "type": "object",
            "required": [
                "id",
                "name"
